#include <iostream>
using namespace std;
class Cuadrado
{
    private:
        int lado1;
    public:
        void inicializar();
        void imprimir();
};

void Cuadrado::inicializar()
{
    cout <<"Ingrese el lado:";
    cin >> lado1;
}
void Cuadrado::imprimir()
{
    cout << "El perimetro del cuadrado es de: " << lado1 * 4 << endl;
    cout << "La superficie del cuadrado es de: " << lado1 * lado1;
}

int main()
{
    Cuadrado cuadrado;
    cuadrado.inicializar();
    cuadrado.imprimir();
    return 0;
}
